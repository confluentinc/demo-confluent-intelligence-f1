{
  "name": "f1-mq-source",
  "config": {
    "connector.class": "IbmMQSource",
    "kafka.auth.mode": "SERVICE_ACCOUNT",
    "kafka.service.account.id": "<SERVICE_ACCOUNT_ID>",
    "kafka.topic": "race-standings-raw",
    "mq.hostname": "<MQ_PUBLIC_IP>",
    "mq.port": "1414",
